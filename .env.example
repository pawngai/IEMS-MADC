# ============================================================
# IEMS Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Backend reads this project-root .env through backend/app_platform/config/settings.py.
# Frontend is Vite-based and still accepts REACT_APP_* vars through vite.config.mjs.
# ============================================================

# ---- MongoDB ----
MONGO_URL=mongodb://localhost:27017
DB_NAME=iems_db

# ---- Security ----
# REQUIRED — minimum 32 characters.  Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# ---- Live E2E / workflow smoke credentials (optional, local/dev) ----
# Needed when running live scripts against an existing backend.
IEMS_SEED_ADMIN_PASSWORD=
IEMS_E2E_DE_PASSWORD=
IEMS_E2E_VERIFIER_PASSWORD=
IEMS_E2E_ESTABLISHMENT_PASSWORD=
IEMS_E2E_HOO_PASSWORD=
IEMS_E2E_DEALING_PASSWORD=
IEMS_E2E_AUDITOR_PASSWORD=

# ---- Environment ----
# Set ENVIRONMENT=production to enable production-only validations
# (mandatory CORS_ORIGINS, no LAN regex by default, no local-disk document fallback).
# ENVIRONMENT=development

# ---- CORS ----
# Comma-separated origins allowed to call the API.
# REQUIRED in production; localhost defaults apply only in development.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# Optional regex override for local network/dev access. Production leaves
# this empty by default; set CORS_ALLOW_PRIVATE_NETWORK_REGEX=1 to opt into
# the development LAN regex, or supply your own pattern here.
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(?::\d{1,5})?$
# CORS_ALLOW_PRIVATE_NETWORK_REGEX=0

# ---- Rate limiting ----
# slowapi storage URI. Defaults to memory:// (process-local; OK for dev,
# unsafe for multi-worker production). Set a shared backend in production:
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0

# ---- API Metadata (optional) ----
API_TITLE=IEMS
API_DESCRIPTION=Government-grade Integrated Employee Management System
API_VERSION=2.0.0

# ---- File Uploads (optional) ----
# Defaults to <project_root>/uploads
# UPLOAD_DIR=/data/iems/uploads
# DOCUMENT_STORAGE_BACKEND=local
# GCS_BUCKET_NAME=your-documents-bucket
# GCP_PROJECT_ID=your-gcp-project-id
# Local-disk fallback when DOCUMENT_STORAGE_BACKEND=gcs. Defaults to true in
# development and false in production. Override only if your production
# deploy explicitly relies on local-disk fallback.
# DOCUMENT_STORAGE_LOCAL_FALLBACK_ENABLED=0

# ---- Frontend (Vite build-time compatibility) ----
REACT_APP_BACKEND_URL=http://localhost:8000
