BACKEND_IMAGE=us-central1-docker.pkg.dev/your-project-id/iems/myiems-backend:latest
FRONTEND_IMAGE=us-central1-docker.pkg.dev/your-project-id/iems/myiems-frontend:latest
ENVIRONMENT=production
JWT_SECRET=replace-with-a-long-random-secret
DB_NAME=iems_db
MONGO_URL=mongodb://mongo:27017
UPLOAD_DIR=/app/uploads
DOCUMENT_STORAGE_BACKEND=local
CORS_ORIGINS=https://app.example.com
# Recommended when running more than one backend worker/process.
# RATE_LIMIT_STORAGE_URI=redis://redis:6379/0
# If frontend and API are on different sites and refresh cookies are required:
# REFRESH_COOKIE_SAMESITE=none
# REFRESH_COOKIE_DOMAIN=.example.com
API_TITLE=IEMS
API_DESCRIPTION=Government-grade Integrated Employee Management System
API_VERSION=2.0.0
