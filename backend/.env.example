# Backend-focused local environment template.
# The canonical runtime env file is the project-root .env.
# Copy these values into ../.env for local development.

MONGO_URL=mongodb://localhost:27017
DB_NAME=iems_db

# REQUIRED: minimum 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Set ENVIRONMENT=production only for deployed runtimes. Local development
# should leave this unset or use ENVIRONMENT=development.
# ENVIRONMENT=development

# Optional explicit local/dev admin password for bootstrap account sync.
IEMS_SEED_ADMIN_PASSWORD=

# Optional local/live workflow smoke users.
IEMS_E2E_DE_PASSWORD=
IEMS_E2E_VERIFIER_PASSWORD=
IEMS_E2E_ESTABLISHMENT_PASSWORD=
IEMS_E2E_HOO_PASSWORD=
IEMS_E2E_DEALING_PASSWORD=
IEMS_E2E_AUDITOR_PASSWORD=

# Optional CORS overrides
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(?::\d{1,5})?$

# Optional shared rate-limit storage for production-style runs.
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0

# Optional API metadata overrides
API_TITLE=MADC-HRMS
API_DESCRIPTION=MADC Human Resource Management System
API_VERSION=2.0.0

# Optional upload override
# UPLOAD_DIR=C:/path/to/uploads
# DOCUMENT_STORAGE_BACKEND=local
# GCS_BUCKET_NAME=your-documents-bucket
# GCP_PROJECT_ID=your-gcp-project-id

